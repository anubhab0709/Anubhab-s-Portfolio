# Runtime
NODE_ENV=development
PORT=8080

# Database
MONGODB_URI=mongodb://localhost:27017/portfolio
SKIP_DB=false

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-web-client-id

# OpenAI Chatbot
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini
# Optional: custom behavior/persona for chatbot
OPENAI_CHAT_SYSTEM_PROMPT=You are a concise assistant for Anubhab's portfolio website.

# Optional: allow guestbook login with name/email in development
ALLOW_GUESTBOOK_DEV_LOGIN=true

# Optional: allow admin moderation by email
ADMIN_EMAILS=anubhabbhatt.eng@gmail.com

# Contact form (Resend)
CONTACT_TO_EMAIL=heyanubhab@gmail.com
CONTACT_FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: comma-separated pino redact paths
LOG_REDACT_PATHS=req.headers.authorization,req.headers.cookie,req.body.credential,req.body.password,req.body.token,res.headers.set-cookie
