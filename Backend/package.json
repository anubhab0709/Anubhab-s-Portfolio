{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for portfolio website",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "check": "node --check src/server.js",
    "mongo:start": "brew services start mongodb-community@7.0",
    "mongo:stop": "brew services stop mongodb-community@7.0",
    "mongo:status": "brew services list | grep -i mongodb-community@7.0 || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.1",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "resend": "^4.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0"
  }
}
